<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.fragments.detailsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Toolbar Header -->
        <TextView
            android:id="@+id/tvDetailsScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Stock Details"
            android:textColor="@color/on_background"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivBookmark"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_bookmark_border"
            app:layout_constraintBottom_toBottomOf="@id/tvDetailsScreen"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvDetailsScreen"
            app:tint="@color/on_background" />

        <!-- Company Name -->
        <TextView
            android:id="@+id/tvCompanyName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/on_background"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/tvDetailsScreen"
            tools:text="Apple Inc." />

        <!-- Hero Section: Price & Ticker -->
        <TextView
            android:id="@+id/tvCurrentPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/on_background"
            android:textSize="48sp"
            android:fontFamily="sans-serif-black"
            app:layout_constraintStart_toStartOf="@+id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/tvCompanyName"
            tools:text="$150.00" />

        <TextView
            android:id="@+id/tvStockSymbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/tvCurrentPrice"
            tools:text="AAPL" />

        <TextView
            android:id="@+id/tvStockType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBaselineOf="@id/tvStockSymbol"
            app:layout_constraintStart_toEndOf="@id/tvStockSymbol"
            tools:text="Common Stock" />

        <TextView
            android:id="@+id/tvExchange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBaselineOf="@id/tvStockSymbol"
            app:layout_constraintStart_toEndOf="@id/tvStockType"
            tools:text="NASDAQ" />

        <TextView
            android:id="@+id/tvPriceChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/tvStockSymbol"
            tools:text="+1.25% (+$2.50)"
            tools:textColor="@color/finance_positive" />

        <!-- Chart Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvChartContainer"
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:layout_marginTop="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPriceChange">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintBottom_toTopOf="@id/llTimePeriods"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/llTimePeriods"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <TextView
                        android:id="@+id/btn1W"
                        style="@style/TimePeriodButtonStyle"
                        android:text="1W" />

                    <TextView
                        android:id="@+id/btn1M"
                        style="@style/TimePeriodButtonStyle"
                        android:text="1M" />

                    <TextView
                        android:id="@+id/btn3M"
                        style="@style/TimePeriodButtonStyle"
                        android:text="3M" />

                    <TextView
                        android:id="@+id/btn6M"
                        style="@style/TimePeriodButtonStyle"
                        android:text="6M" />

                    <TextView
                        android:id="@+id/btn1Y"
                        style="@style/TimePeriodButtonStyle"
                        android:text="1Y" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- About Section -->
        <TextView
            android:id="@+id/tvAboutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="About"
            android:textColor="@color/on_background"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/cvChartContainer" />

        <TextView
            android:id="@+id/tvAboutDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@+id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/tvAboutTitle"
            tools:text="Apple Inc. designs, manufactures, and markets smartphones, personal computers, tablets, wearables, and accessories worldwide." />

        <LinearLayout
            android:id="@+id/llTags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@+id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@+id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/tvAboutDescription">

            <TextView
                android:id="@+id/tvIndustryTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tag_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Technology" />

            <TextView
                android:id="@+id/tvSectorTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/tag_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Consumer Electronics" />
        </LinearLayout>

        <!-- Statistics Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvStatsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
            app:cardCornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="@+id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@+id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/llTags">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- Column 1 -->
                <TextView
                    android:id="@+id/tvMarketCapLabel"
                    style="@style/StatLabelStyle"
                    android:text="Market Cap"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvMarketCapValue"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvMarketCapLabel"
                    tools:text="2.8T" />

                <TextView
                    android:id="@+id/tvPERatioLabel"
                    style="@style/StatLabelStyle"
                    android:layout_marginTop="20dp"
                    android:text="P/E Ratio"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvMarketCapValue" />

                <TextView
                    android:id="@+id/tvPERatioValue"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvPERatioLabel"
                    tools:text="28.5" />

                <TextView
                    android:id="@+id/tvBetaLabel"
                    style="@style/StatLabelStyle"
                    android:layout_marginTop="20dp"
                    android:text="Beta"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvPERatioValue" />

                <TextView
                    android:id="@+id/tvBetaValue"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvBetaLabel"
                    tools:text="1.2" />

                <TextView
                    android:id="@+id/tv52WeekLowLabel"
                    style="@style/StatLabelStyle"
                    android:layout_marginTop="20dp"
                    android:text="52 Week Low"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvBetaValue" />

                <TextView
                    android:id="@+id/tvLowPrice"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv52WeekLowLabel"
                    tools:text="$124.17" />

                <!-- Column 2 -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineVerticalCenter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />

                <TextView
                    android:id="@+id/tvDividendYieldLabel"
                    style="@style/StatLabelStyle"
                    android:text="Div. Yield"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvDividendYieldValue"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toBottomOf="@id/tvDividendYieldLabel"
                    tools:text="0.58%" />

                <TextView
                    android:id="@+id/tvProfitMarginLabel"
                    style="@style/StatLabelStyle"
                    android:layout_marginTop="20dp"
                    android:text="Profit Margin"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toBottomOf="@id/tvDividendYieldValue" />

                <TextView
                    android:id="@+id/tvProfitMarginValue"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toBottomOf="@id/tvProfitMarginLabel"
                    tools:text="25.3%" />

                <TextView
                    android:id="@+id/tvCurrentPriceStat"
                    style="@style/StatLabelStyle"
                    android:layout_marginTop="20dp"
                    android:text="Prev Close"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toBottomOf="@id/tvProfitMarginValue" />

                <TextView
                    android:id="@+id/tvCurrentPriceValue"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toBottomOf="@id/tvCurrentPriceStat"
                    tools:text="$148.50" />

                <TextView
                    android:id="@+id/tv52WeekHighLabel"
                    style="@style/StatLabelStyle"
                    android:layout_marginTop="20dp"
                    android:text="52 Week High"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toBottomOf="@id/tvCurrentPriceValue" />

                <TextView
                    android:id="@+id/tvHighPrice"
                    style="@style/StatValueStyle"
                    app:layout_constraintStart_toStartOf="@id/guidelineVerticalCenter"
                    app:layout_constraintTop_toBottomOf="@id/tv52WeekHighLabel"
                    tools:text="$198.23" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Guidelines for consistent padding -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="20dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="20dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
